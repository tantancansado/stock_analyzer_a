# Flask Configuration
FLASK_ENV=production
FLASK_DEBUG=False
REQUIRE_SUPABASE_AUTH=true
AUTH_BYPASS=false

# Server Configuration
PORT=5001
HOST=0.0.0.0
SUPABASE_URL=https://YOUR_PROJECT.supabase.co

# CORS Configuration (add your GitHub Pages URL)
ALLOWED_ORIGINS=https://YOUR_USERNAME.github.io,http://localhost:5173

# Stock Data API Keys (OPTIONAL - for fallback only)
# Get cookies from browser: Chrome DevTools > Network > Any request to seekingalpha.com > Copy Cookie header
SEEKING_ALPHA_COOKIES=machine_cookie=xxx; session_id=xxx; _pxvid=xxx; ...

# Optional: Rate Limiting
MAX_REQUESTS_PER_HOUR=100
MAX_REQUESTS_PER_DAY=500
RATE_LIMIT_STORAGE_URI=memory://
                    